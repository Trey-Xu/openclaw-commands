{
  "id": "system",
  "name": "系统与维护",
  "nameEn": "System & Maintenance",
  "icon": "🔧",
  "description": "系统监控、日志、安全、备份、更新和维护",
  "descriptionEn": "System monitoring, logs, security, backup, updates, and maintenance",
  "commands": [
    {
      "name": "status",
      "description": "查看会话健康状态和最近的接收者",
      "descriptionEn": "Show linked session health and recent recipients",
      "syntax": "openclaw status [options]",
      "options": [
        { "flag": "--all", "description": "完整诊断（只读，可粘贴分享）", "descriptionEn": "Full diagnosis (read-only, pasteable)" },
        { "flag": "--deep", "description": "探测频道", "descriptionEn": "Probe channels" },
        { "flag": "--usage", "description": "显示模型提供商用量/配额", "descriptionEn": "Show model provider usage/quota" },
        { "flag": "--verbose", "description": "详细输出", "descriptionEn": "Verbose output" },
        { "flag": "--debug", "description": "--verbose 的别名", "descriptionEn": "Alias for --verbose" },
        { "flag": "--json", "description": "JSON 输出", "descriptionEn": "JSON output" },
        { "flag": "--timeout <ms>", "description": "超时时间", "descriptionEn": "Timeout" }
      ],
      "examples": [
        { "description": "查看概览状态", "descriptionEn": "View status overview", "code": "openclaw status" },
        { "description": "深度诊断", "descriptionEn": "Deep diagnosis", "code": "openclaw status --all" },
        { "description": "查看用量", "descriptionEn": "View usage", "code": "openclaw status --usage" }
      ],
      "subcommands": []
    },
    {
      "name": "health",
      "description": "从运行中的 Gateway 获取健康状态",
      "descriptionEn": "Fetch health from running Gateway",
      "syntax": "openclaw health [options]",
      "options": [
        { "flag": "--verbose", "description": "详细输出", "descriptionEn": "Verbose output" },
        { "flag": "--debug", "description": "--verbose 的别名", "descriptionEn": "Alias for --verbose" },
        { "flag": "--timeout <ms>", "description": "超时时间", "descriptionEn": "Timeout" },
        { "flag": "--json", "description": "JSON 输出", "descriptionEn": "JSON output" }
      ],
      "examples": [
        { "description": "检查健康状态", "descriptionEn": "Check health", "code": "openclaw health --json" }
      ],
      "subcommands": []
    },
    {
      "name": "sessions",
      "description": "列出存储的对话会话",
      "descriptionEn": "List stored conversation sessions",
      "syntax": "openclaw sessions [options]",
      "options": [
        { "flag": "--store <path>", "description": "会话存储路径（默认从配置解析）", "descriptionEn": "Session store path (default resolved from config)" },
        { "flag": "--agent <id>", "description": "指定 Agent（默认使用默认 Agent）", "descriptionEn": "Agent id (default: configured default)" },
        { "flag": "--all-agents", "description": "聚合所有 Agent 的会话", "descriptionEn": "Aggregate sessions across all configured agents" },
        { "flag": "--active <minutes>", "description": "仅显示最近 N 分钟内更新的会话", "descriptionEn": "Only sessions updated within the past N minutes" },
        { "flag": "--verbose", "description": "详细输出", "descriptionEn": "Verbose output" },
        { "flag": "--json", "description": "JSON 输出", "descriptionEn": "Output JSON" }
      ],
      "examples": [
        { "description": "列出所有会话", "descriptionEn": "List all sessions", "code": "openclaw sessions" },
        { "description": "指定 Agent", "descriptionEn": "List sessions for one agent", "code": "openclaw sessions --agent work" },
        { "description": "聚合所有 Agent", "descriptionEn": "Aggregate across agents", "code": "openclaw sessions --all-agents" },
        { "description": "仅显示最近 2 小时", "descriptionEn": "Only last 2 hours", "code": "openclaw sessions --active 120" },
        { "description": "JSON 输出", "descriptionEn": "Machine-readable output", "code": "openclaw sessions --json" }
      ],
      "subcommands": [
        { "name": "cleanup", "description": "立即运行会话存储维护（清理/保留策略）", "descriptionEn": "Run session-store maintenance now" }
      ]
    },
    {
      "name": "logs",
      "description": "通过 RPC 尾随 Gateway 文件日志",
      "descriptionEn": "Tail Gateway file logs via RPC",
      "syntax": "openclaw logs [options]",
      "options": [
        { "flag": "--follow", "description": "持续跟踪日志", "descriptionEn": "Follow log output" },
        { "flag": "--limit <n>", "description": "显示行数", "descriptionEn": "Number of lines" },
        { "flag": "--plain", "description": "纯文本输出", "descriptionEn": "Plain text output" },
        { "flag": "--json", "description": "JSON 行分隔输出", "descriptionEn": "JSON line-delimited output" },
        { "flag": "--no-color", "description": "禁用颜色", "descriptionEn": "Disable colors" }
      ],
      "examples": [
        { "description": "实时跟踪日志", "descriptionEn": "Follow logs in real-time", "code": "openclaw logs --follow" },
        { "description": "查看最近 200 行", "descriptionEn": "View last 200 lines", "code": "openclaw logs --limit 200" },
        { "description": "JSON 格式输出", "descriptionEn": "JSON format output", "code": "openclaw logs --json" }
      ],
      "subcommands": []
    },
    {
      "name": "system",
      "description": "系统事件、心跳和在线状态管理",
      "descriptionEn": "System events, heartbeat, and presence management",
      "syntax": "openclaw system <subcommand> [options]",
      "options": [
        { "flag": "--url <url>", "description": "Gateway URL", "descriptionEn": "Gateway URL" },
        { "flag": "--token <token>", "description": "Gateway 令牌", "descriptionEn": "Gateway token" },
        { "flag": "--timeout <ms>", "description": "超时时间", "descriptionEn": "Timeout" },
        { "flag": "--json", "description": "JSON 输出", "descriptionEn": "JSON output" }
      ],
      "examples": [
        { "description": "发送系统事件", "descriptionEn": "Send system event", "code": "openclaw system event --text \"Deployment complete\" --mode notify" },
        { "description": "查看最近心跳", "descriptionEn": "View last heartbeat", "code": "openclaw system heartbeat last" },
        { "description": "启用心跳", "descriptionEn": "Enable heartbeat", "code": "openclaw system heartbeat enable" },
        { "description": "查看在线状态", "descriptionEn": "View presence", "code": "openclaw system presence" }
      ],
      "subcommands": [
        { "name": "event", "description": "发送系统事件，需 --text", "descriptionEn": "Send system event, requires --text" },
        { "name": "heartbeat last", "description": "查看最近心跳", "descriptionEn": "View last heartbeat" },
        { "name": "heartbeat enable", "description": "启用心跳", "descriptionEn": "Enable heartbeat" },
        { "name": "heartbeat disable", "description": "禁用心跳", "descriptionEn": "Disable heartbeat" },
        { "name": "presence", "description": "列出系统在线状态", "descriptionEn": "List system presence" }
      ]
    },
    {
      "name": "update",
      "description": "更新 OpenClaw（支持更新渠道/目标 tag、试运行、非交互）；执行全局 npm 安装前会预检目标包的 engines.node",
      "descriptionEn": "Update OpenClaw (channels/tags, dry-run, non-interactive); preflights target npm package engines.node before global install",
      "syntax": "openclaw update [options] [subcommand]",
      "options": [
        { "flag": "--json", "description": "JSON 输出", "descriptionEn": "Output JSON" },
        { "flag": "--no-restart", "description": "更新成功后不重启 Gateway 服务", "descriptionEn": "Skip restarting the gateway service after update" },
        { "flag": "--dry-run", "description": "试运行（仅预览，不做实际更改）", "descriptionEn": "Preview update actions without making changes" },
        { "flag": "--channel <stable|beta|dev>", "description": "持久化更新渠道（git + npm）", "descriptionEn": "Persist update channel (git + npm)" },
        { "flag": "--tag <tag|version|spec>", "description": "一次性覆盖更新目标（dist-tag/版本/包 spec）", "descriptionEn": "Override the update target (dist-tag/version/package spec)" },
        { "flag": "--timeout <seconds>", "description": "每步超时（秒，默认 1200）", "descriptionEn": "Timeout per step in seconds (default: 1200)" },
        { "flag": "--yes", "description": "无交互接受确认（例如降级确认）", "descriptionEn": "Skip confirmation prompts (non-interactive)" }
      ],
      "examples": [
        { "description": "更新 OpenClaw", "descriptionEn": "Update OpenClaw", "code": "openclaw update" },
        { "description": "切换到 beta 渠道", "descriptionEn": "Switch to beta channel", "code": "openclaw update --channel beta" },
        { "description": "试运行预览更新动作", "descriptionEn": "Preview update plan", "code": "openclaw update --dry-run" },
        { "description": "交互式更新向导", "descriptionEn": "Interactive update wizard", "code": "openclaw update wizard" },
        { "description": "查看更新渠道与版本状态", "descriptionEn": "Show update status", "code": "openclaw update status" }
      ],
      "subcommands": [
        { "name": "wizard", "description": "交互式更新向导", "descriptionEn": "Interactive update wizard" },
        { "name": "status", "description": "查看更新渠道与版本状态", "descriptionEn": "Show update channel and version status" }
      ]
    },

{
  "id": "system",
  "name": "系统与维护",
  "nameEn": "System & Maintenance",
  "icon": "🔧",
  "description": "系统监控、日志、安全、备份、更新和维护",
  "descriptionEn": "System monitoring, logs, security, backup, updates, and maintenance",
  "commands": [
    {
      "name": "status",
      "description": "查看会话健康状态和最近的接收者",
      "descriptionEn": "Show linked session health and recent recipients",
      "syntax": "openclaw status [options]",
      "options": [
        { "flag": "--all", "description": "完整诊断（只读，可粘贴分享）", "descriptionEn": "Full diagnosis (read-only, pasteable)" },
        { "flag": "--deep", "description": "探测频道", "descriptionEn": "Probe channels" },
        { "flag": "--usage", "description": "显示模型提供商用量/配额", "descriptionEn": "Show model provider usage/quota" },
        { "flag": "--verbose", "description": "详细输出", "descriptionEn": "Verbose output" },
        { "flag": "--json", "description": "JSON 输出", "descriptionEn": "JSON output" },
        { "flag": "--timeout <ms>", "description": "超时时间", "descriptionEn": "Timeout" }
      ],
      "examples": [
        { "description": "查看概览状态", "descriptionEn": "View status overview", "code": "openclaw status" },
        { "description": "深度诊断", "descriptionEn": "Deep diagnosis", "code": "openclaw status --all" },
        { "description": "查看用量", "descriptionEn": "View usage", "code": "openclaw status --usage" }
      ],
      "subcommands": []
    },
    {
      "name": "health",
      "description": "从运行中的 Gateway 获取健康状态",
      "descriptionEn": "Fetch health from running Gateway",
      "syntax": "openclaw health [options]",
      "options": [
        { "flag": "--verbose", "description": "详细输出", "descriptionEn": "Verbose output" },
        { "flag": "--timeout <ms>", "description": "超时时间", "descriptionEn": "Timeout" },
        { "flag": "--json", "description": "JSON 输出", "descriptionEn": "JSON output" }
      ],
      "examples": [
        { "description": "检查健康状态", "descriptionEn": "Check health", "code": "openclaw health --json" }
      ],
      "subcommands": []
    },
    {
      "name": "sessions",
      "description": "列出存储的对话会话",
      "descriptionEn": "List stored conversation sessions",
      "syntax": "openclaw sessions [options]",
      "options": [
        { "flag": "--active <filter>", "description": "活跃会话过滤", "descriptionEn": "Active session filter" },
        { "flag": "--store <store>", "description": "指定存储", "descriptionEn": "Specify store" },
        { "flag": "--verbose", "description": "详细输出", "descriptionEn": "Verbose output" },
        { "flag": "--json", "description": "JSON 输出", "descriptionEn": "JSON output" }
      ],
      "examples": [
        { "description": "列出所有会话", "descriptionEn": "List all sessions", "code": "openclaw sessions --json" }
      ],
      "subcommands": []
    },
    {
      "name": "logs",
      "description": "通过 RPC 尾随 Gateway 文件日志",
      "descriptionEn": "Tail Gateway file logs via RPC",
      "syntax": "openclaw logs [options]",
      "options": [
        { "flag": "--follow", "description": "持续跟踪日志", "descriptionEn": "Follow log output" },
        { "flag": "--limit <n>", "description": "显示行数", "descriptionEn": "Number of lines" },
        { "flag": "--plain", "description": "纯文本输出", "descriptionEn": "Plain text output" },
        { "flag": "--json", "description": "JSON 行分隔输出", "descriptionEn": "JSON line-delimited output" },
        { "flag": "--no-color", "description": "禁用颜色", "descriptionEn": "Disable colors" }
      ],
      "examples": [
        { "description": "实时跟踪日志", "descriptionEn": "Follow logs in real-time", "code": "openclaw logs --follow" },
        { "description": "查看最近 200 行", "descriptionEn": "View last 200 lines", "code": "openclaw logs --limit 200" },
        { "description": "JSON 格式输出", "descriptionEn": "JSON format output", "code": "openclaw logs --json" }
      ],
      "subcommands": []
    },
    {
      "name": "system",
      "description": "系统事件、心跳和在线状态管理",
      "descriptionEn": "System events, heartbeat, and presence management",
      "syntax": "openclaw system <subcommand> [options]",
      "options": [
        { "flag": "--url <url>", "description": "Gateway URL", "descriptionEn": "Gateway URL" },
        { "flag": "--token <token>", "description": "Gateway 令牌", "descriptionEn": "Gateway token" },
        { "flag": "--timeout <ms>", "description": "超时时间", "descriptionEn": "Timeout" },
        { "flag": "--json", "description": "JSON 输出", "descriptionEn": "JSON output" }
      ],
      "examples": [
        { "description": "发送系统事件", "descriptionEn": "Send system event", "code": "openclaw system event --text \"Deployment complete\" --mode notify" },
        { "description": "查看最近心跳", "descriptionEn": "View last heartbeat", "code": "openclaw system heartbeat last" },
        { "description": "启用心跳", "descriptionEn": "Enable heartbeat", "code": "openclaw system heartbeat enable" },
        { "description": "查看在线状态", "descriptionEn": "View presence", "code": "openclaw system presence" }
      ],
      "subcommands": [
        { "name": "event", "description": "发送系统事件，需 --text", "descriptionEn": "Send system event, requires --text" },
        { "name": "heartbeat last", "description": "查看最近心跳", "descriptionEn": "View last heartbeat" },
        { "name": "heartbeat enable", "description": "启用心跳", "descriptionEn": "Enable heartbeat" },
        { "name": "heartbeat disable", "description": "禁用心跳", "descriptionEn": "Disable heartbeat" },
        { "name": "presence", "description": "列出系统在线状态", "descriptionEn": "List system presence" }
      ]
    },

    {
      "name": "reset",
      "description": "重置本地配置/状态（保留 CLI）",
      "descriptionEn": "Reset local config/state (keeps CLI installed)",
      "syntax": "openclaw reset [options]",
      "options": [
        { "flag": "--scope <scope>", "description": "重置范围", "descriptionEn": "Reset scope" },
        { "flag": "--dry-run", "description": "试运行，不实际执行", "descriptionEn": "Dry run, no actual changes" },
        { "flag": "--non-interactive", "description": "无交互模式（需配合 --scope 和 --yes）", "descriptionEn": "Non-interactive (requires --scope and --yes)" },
        { "flag": "--yes", "description": "接受默认值", "descriptionEn": "Accept defaults" }
      ],
      "examples": [
        { "description": "交互式重置", "descriptionEn": "Interactive reset", "code": "openclaw reset" },
        { "description": "试运行查看影响", "descriptionEn": "Dry run to preview", "code": "openclaw reset --dry-run" }
      ],
      "subcommands": []
    },
    {
      "name": "uninstall",
      "description": "卸载 Gateway 服务和本地数据（CLI 保留）",
      "descriptionEn": "Uninstall Gateway service and local data (CLI remains)",
      "syntax": "openclaw uninstall [options]",
      "options": [
        { "flag": "--all", "description": "卸载所有", "descriptionEn": "Uninstall all" },
        { "flag": "--service", "description": "仅卸载服务", "descriptionEn": "Service only" },
        { "flag": "--state", "description": "仅删除状态", "descriptionEn": "State only" },
        { "flag": "--workspace", "description": "仅删除工作区", "descriptionEn": "Workspace only" },
        { "flag": "--app", "description": "仅删除应用", "descriptionEn": "App only" },
        { "flag": "--dry-run", "description": "试运行", "descriptionEn": "Dry run" },
        { "flag": "--non-interactive", "description": "无交互（需 --yes 和范围）", "descriptionEn": "Non-interactive (requires --yes and scope)" },
        { "flag": "--yes", "description": "确认", "descriptionEn": "Confirm" }
      ],
      "examples": [
        { "description": "完全卸载", "descriptionEn": "Full uninstall", "code": "openclaw uninstall --all --yes" },
        { "description": "仅卸载服务", "descriptionEn": "Uninstall service only", "code": "openclaw uninstall --service" }
      ],
      "subcommands": []
    },

    {
      "name": "backup",
      "description": "创建和验证 OpenClaw 本地状态备份包",
      "descriptionEn": "Create and verify local backup archives for OpenClaw state",
      "syntax": "openclaw backup <subcommand> [options]",
      "options": [
        { "flag": "--output <path>", "description": "输出文件或目录（create）", "descriptionEn": "Archive path or destination directory (create)" },
        { "flag": "--json", "description": "JSON 输出（create/verify）", "descriptionEn": "Output JSON (create/verify)" },
        { "flag": "--dry-run", "description": "预览备份计划不写入（create）", "descriptionEn": "Print the backup plan without writing (create)" },
        { "flag": "--verify", "description": "创建后立即校验（create）", "descriptionEn": "Verify the archive after writing it (create)" },
        { "flag": "--only-config", "description": "仅备份当前 JSON 配置文件（create）", "descriptionEn": "Back up only the active JSON config file (create)" },
        { "flag": "--no-include-workspace", "description": "不包含工作区目录（create）", "descriptionEn": "Exclude workspace directories from the backup (create)" }
      ],
      "examples": [
        { "description": "创建备份", "descriptionEn": "Create backup", "code": "openclaw backup create" },
        { "description": "验证备份", "descriptionEn": "Verify backup", "code": "openclaw backup verify ./openclaw-backup.tar.gz" },
        { "description": "预览备份计划（不写入）", "descriptionEn": "Preview plan without writing", "code": "openclaw backup create --dry-run --json" },
        { "description": "创建后立即校验", "descriptionEn": "Create and verify immediately", "code": "openclaw backup create --verify" }
      ],
      "subcommands": [
        { "name": "create", "description": "创建备份（可选输出路径、是否包含工作区等）", "descriptionEn": "Write a backup archive (output path, include workspace, etc.)" },
        { "name": "verify <archive>", "description": "验证备份包及其内置清单", "descriptionEn": "Validate a backup archive and its embedded manifest" }
      ]
    },
